{
  "openapi": "1.0.0",
  "info": {
    "title": "Kyzen.id",
    "author": "Kyzen.id",
    "version": "v1.0.0",
    "description": "Simple and easy to use API."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "AI"
    },
    {
      "name": "Anime"
    },
    {
      "name": "Downloader"
    },
    {
      "name": "Image"
    },
    {
      "name": "News"
    }
  ],
  "paths": {
    "/ai/copilot": {
      "get": {
        "summary": "Copilot Chat",
        "description": "Kirim pertanyaan ke Copilot Microsoft dan dapatkan jawaban beserta referensi/citations",
        "tags": [
          "AI"
        ],
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": true,
            "description": "Pesan atau pertanyaan yang ingin dikirim ke Copilot",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "model",
            "in": "query",
            "required": false,
            "description": "Model Copilot yang digunakan (default: 'default', opsional: 'think-deeper', 'gpt-5')",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "think-deeper",
                "gpt-5"
              ],
              "default": "default"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan jawaban dari Copilot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string",
                      "example": "Berikut adalah berita terbaru dari Indonesia..."
                    },
                    "citations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": {
                            "type": "string",
                            "example": "Detik News"
                          },
                          "icon": {
                            "type": "string",
                            "example": "https://example.com/icon.png"
                          },
                          "url": {
                            "type": "string",
                            "format": "uri",
                            "example": "https://www.detik.com/..."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Request invalid, message kosong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string",
                      "example": "Message wajib diisi"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string",
                      "example": "Gagal memproses request"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ai/venice": {
      "get": {
        "summary": "Venice AI Chat",
        "description": "Mengirim pertanyaan ke model Venice AI dan mendapatkan jawaban final.",
        "tags": [
          "AI"
        ],
        "parameters": [
          {
            "name": "message",
            "in": "query",
            "required": true,
            "description": "Teks atau pertanyaan yang ingin dikirim ke Venice AI",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan jawaban dari Venice AI",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": true
                    },
                    "result": {
                      "type": "string",
                      "example": "Halo! Saya Venice AI, siap membantu Anda menjawab pertanyaan atau membuat konten kreatif."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Request invalid, message kosong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string",
                      "example": "Pesan wajib diisi"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "error": {
                      "type": "string",
                      "example": "Gagal memproses request"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/anime/waifu": {
      "get": {
        "summary": "Waifu",
        "description": "Mengambil gambar waifu secara acak dari API waifu.pics.",
        "tags": [
          "Anime"
