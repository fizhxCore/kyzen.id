    "/download/capcut": {
      "get": {
        "summary": "CapCut Downloader",
        "description": "Ambil data dan video template dari CapCut berdasarkan URL template",
        "tags": [
          "Downloader"
        ],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "description": "URL template CapCut yang ingin diambil datanya",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Respon berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": true
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "type": "string",
                          "example": "Template Name"
                        },
                        "description": {
                          "type": "string",
                          "example": "Template Description"
                        },
                        "thumbnail": {
                          "type": "string",
                          "format": "uri"
                        },
                        "video": {
                          "type": "string",
                          "format": "uri"
                        },
                        "author": {
                          "type": "string",
                          "example": "Author Name"
                        },
                        "avatar": {
                          "type": "string",
                          "format": "uri"
                        },
                        "duration": {
                          "type": "number",
                          "example": 15
                        },
                        "likes": {
                          "type": "integer",
                          "example": 1200
                        },
                        "uses": {
                          "type": "integer",
                          "example": 300
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "URL tidak disertakan"
          },
          "500": {
            "description": "Gagal memproses request"
          }
        }
      }
    },
    "/download/pinterest": {
      "get": {
        "summary": "Pinterest ",
        "description": "Mengambil data dan link media (video/image) dari URL Pinterest / pin.it.",
        "tags": [
          "Downloader"
        ],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "description": "URL Pinterest / pin.it yang ingin di-download",
            "required": true,
            "schema": {
              "type": "string",
              "example": "https://pin.it/lOPdveAO7"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Berhasil mengambil data Pinterest",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": true
                    },
                    "creator": {
                      "type": "string",
                      "example": "Kyzen.id"
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "example": "video"
                        },
                        "title": {
                          "type": "string",
                          "example": "Art"
                        },
                        "author": {
                          "type": "string",
                          "example": "ShiroAMV7"
                        },
                        "username": {
                          "type": "string",
                          "example": "shiroamv7"
                        },
                        "media": {
                          "type": "string",
                          "example": "https://v1.pinimg.com/videos/iht/expMp4/..."
                        },
                        "pinterest_url": {
                          "type": "string",
                          "example": "https://pin.it/lOPdveAO7"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "URL tidak valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "creator": {
                      "type": "string",
                      "example": "Kyzen.id"
                    },
                    "error": {
                      "type": "string",
                      "example": "URL harus dari Pinterest / pin.it"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Gagal memproses request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean",
                      "example": false
                    },
                    "creator": {
                      "type": "string",
                      "example": "Kyzen.id"
                    },
                    "error": {
                      "type": "string",
                      "example": "Gagal memproses request"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
